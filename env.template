# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional non-interactive CLI overrides for dry-run / paper-run / replay
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
# TRADINGAGENTS_BACKEND_URL=https://api.openai.com/v1
# TRADINGAGENTS_OPENAI_REASONING_EFFORT=medium
# TRADINGAGENTS_GOOGLE_THINKING_LEVEL=high
# TRADINGAGENTS_ANTHROPIC_EFFORT=medium

# Optional market data
ALPHA_VANTAGE_API_KEY=

# Alpaca paper trading only
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_FEED=iex
ALPACA_REQUEST_TIMEOUT_SECONDS=10
ALPACA_REQUEST_MAX_RETRIES=3
PAPER_TRADING_ENABLED=false

# Local runtime paths
EXECUTION_DB_PATH=./runtime/tradingagents.db
TRADINGAGENTS_RESULTS_DIR=./results
LOG_LEVEL=INFO

# Optional hosted dashboard settings
# TRADINGAGENTS_DASHBOARD_PROXY_URL=https://your-daemon-host.example.com
# TRADINGAGENTS_VERCEL_REFRESH_SECONDS=15

# Daemon and scheduler
AGENT_ID=primary

# NOTE: ARENA_ENABLED=false means the arena LLM layer is skipped and the
# research engine's parsed decision flows directly to the risk engine.
# Re-enable after validating that the parser extracts enough structured
# fields for the risk engine to approve well-reasoned trades.
ARENA_ENABLED=false
# ARENA_MODEL=gpt-5.4-mini
AGENT_MEMORY_LIMIT=10
WATCHLIST_PRESET=sp500
# WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA
MAX_SYMBOLS_PER_CYCLE=5
SCHEDULER_INTERVAL_MINUTES=15
MAX_TRADES_PER_CYCLE=0
DAEMON_POLL_SECONDS=15
MARKET_OPEN_SLEEP_SECONDS=15
MARKET_CLOSED_SLEEP_SECONDS=300
DAEMON_PID_PATH=./runtime/daemon.pid
DAEMON_LOCK_PATH=./runtime/daemon.lock
DAEMON_HEARTBEAT_PATH=./runtime/daemon-heartbeat.json
DAILY_SUMMARY_DIR=./results/daily
KILL_SWITCH_PATH=./runtime/KILL_SWITCH
CONSERVATIVE_SPREAD_BPS=10
MARKET_TIMEZONE=America/New_York
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00
# MARKET_HOLIDAYS=2026-12-25,2026-01-01

# Optional execution guardrails
# Default runtime data vendors
# TRADINGAGENTS_CORE_STOCK_VENDOR=alpaca
# TRADINGAGENTS_TECHNICAL_VENDOR=alpaca
# TRADINGAGENTS_FUNDAMENTAL_VENDOR=alpaca
# TRADINGAGENTS_NEWS_VENDOR=alpaca
#
# Timeout guards to prevent a single slow request from freezing the daemon
# SYMBOL_ANALYSIS_TIMEOUT_SECONDS=180
# CYCLE_CONTEXT_TIMEOUT_SECONDS=45
#
# ALLOWED_SYMBOLS=NVDA,AAPL
# Risk thresholds — tuned for active paper trading
MIN_CONFIDENCE_THRESHOLD=0.65
MIN_SIGNALS_REQUIRED=2
REQUIRE_MULTIPLE_SIGNALS=true
DEFAULT_TO_HOLD=true
EXTRA_CONFIDENCE_THRESHOLD_AFTER_RECENT_TRADE=0.05

# Position sizing — allow small starter positions
DEFAULT_POSITION_SIZE_PCT=0.03
MAX_POSITION_NOTIONAL_PCT_PER_SYMBOL=0.25
# MAX_POSITION_NOTIONAL_PCT=0.25
MAX_TOTAL_GROSS_EXPOSURE_PCT=0.60
MAX_TOTAL_EXPOSURE_PCT=0.60
MAX_ORDER_NOTIONAL_USD=2000
MIN_ORDER_NOTIONAL_USD=100

# Allow gradual position building
ALLOW_SCALING_IN=false
BLOCK_REENTRY_WHILE_POSITION_OPEN=true
ALLOW_POSITION_SCALING=false

# Trade frequency — rely on quality checks, not hard caps
# MAX_NEW_POSITIONS_PER_DAY=3
MAX_DAILY_TRADES=0
MAX_DAILY_TRADES_PER_SYMBOL=0
MAX_TRADES_PER_CYCLE=0
SYMBOL_COOLDOWN_MINUTES=30

# Cooldowns
POSITION_REENTRY_COOLDOWN_HOURS=2
REVERSAL_COOLDOWN_HOURS=4

# Optional remaining execution guardrails
# MAX_NEW_POSITIONS_PER_DAY=3
# TRADE_FREQUENCY_PENALTY_ENABLED=true
# RECENT_TRADE_LOOKBACK_MINUTES=120
# MAX_OPEN_POSITIONS=5
# MAX_DAILY_LOSS_PCT=0.03
# REJECT_SHORT_SELLING=true
# REJECT_FRACTIONAL_SHARES=true
# ALLOW_FRACTIONAL_SHARES=false
# ALLOW_REVERSAL=false
# MARKET_HOURS_ONLY=true
# COOLDOWN_MINUTES_PER_SYMBOL=60
# REQUIRE_EXPECTED_EDGE=true
# REQUIRE_MARKET_MISPRICING_REASON=true
# REQUIRE_NEW_INFORMATION_CHECK=true
# REQUIRE_POSITION_SIZING_RATIONALE=true
# REJECT_IF_CONTRADICTS_RECENT_FAILURES=true
# MAX_FLIP_FLOPS_PER_SYMBOL_PER_DAY=1
